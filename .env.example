# Copy this file to `.env` and fill in real values for local development.
# `config/local.js` is also picked up by Sails if you prefer that style.

# --- Sails / app
PORT=1337
APP_URL=http://localhost:1337

# --- Postgres
# Either DATABASE_URL or the individual fields below; the URL takes priority.
DATABASE_URL=postgres://blog:blog@localhost:5432/skeleton_challenge

# --- JWT
JWT_SECRET=change-me-please
JWT_TTL=7d

# --- Sessions (Sails uses an in-memory store by default in dev)
SESSION_SECRET=change-me-too

# --- Password reset email (Ethereal SMTP for dev)
# Generate test creds at https://ethereal.email/ and paste them here.
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Skeleton Challenge <noreply@skeleton.local>"
