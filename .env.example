# Copy this file to `.env` and fill in real values for local development.
# `config/local.js` is also picked up by Sails if you prefer that style.

# --- Sails / app
PORT=1337
APP_URL=http://localhost:1337

# --- Postgres
# Either DATABASE_URL or the individual fields below; the URL takes priority.
# `docker-compose.yml` runs Postgres on host port 5433 to avoid clashing with
# a system Postgres on 5432; adjust if you bring your own database.
DATABASE_URL=postgres://blog:blog@localhost:5433/skeleton_challenge

# --- JWT (sign your own — anything 32+ random hex chars works)
JWT_SECRET=change-me-please-32-random-hex-chars
JWT_TTL=7d

# --- Sessions (Sails wants a secret to lift; not actively used)
SESSION_SECRET=change-me-too

# --- Password reset / email verification
# Default: leave SMTP_USER/SMTP_PASS empty and the mailer falls back to a
# one-off Ethereal account. The preview URL gets logged to the sails console,
# so the flows can be exercised without setting up real SMTP.
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Skeleton Challenge <noreply@skeleton.local>"

# --- For real mail via SendGrid, swap to (and verify a sender in SendGrid):
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxxxxxxxxxxxxxxxxxxxxx
# MAIL_FROM="Skeleton Challenge <verified@yourdomain.com>"
