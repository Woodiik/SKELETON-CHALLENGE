<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Skeleton Challenge' %></title>
  <link rel="icon" href="/favicon.ico">
  <%- typeof viteAsset === 'function' ? viteAsset('src/main.js') : '' %>
</head>
<body class="min-h-screen">
  <header class="border-b border-slate-200 bg-white">
    <div class="mx-auto flex max-w-4xl items-center justify-between px-6 py-4">
      <a href="/" class="text-lg font-semibold text-slate-900">Skeleton Blog</a>
      <div id="site-header" class="text-sm text-slate-700">
        <nav class="flex gap-4">
          <a href="/login" class="hover:underline">Login</a>
          <a href="/signup" class="hover:underline">Sign up</a>
        </nav>
      </div>
    </div>
  </header>
  <div id="verify-banner"></div>
  <main class="mx-auto max-w-3xl px-6 py-8">
    <%- body %>
  </main>
  <div id="toast-host"></div>
</body>
</html>
